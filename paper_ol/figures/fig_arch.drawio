        <mxCell id="a9" value="next batch" style="endArrow=open;html=1;strokeColor=#666666;fontFamily=Times New Roman;fontSize=10;exitX=0.5;exitY=0;entryX=0.5;entryY=1" edge="1" source="p8" target="inp" parent="1">
